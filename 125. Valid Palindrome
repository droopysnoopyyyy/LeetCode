class Solution {
public:
    bool isPalindrome(string s) {
        for (char& c : s) {
        c = tolower(c);
        }
        char* ptr_a = &s[0];
        char* ptr_b = &s[s.size()-1];
        for (int i = 0; ptr_a < ptr_b; i++) {
            if (!isalnum(*ptr_a)) {
                ptr_a++;
                continue;
            }
            else if (!isalnum(*ptr_b)) {
                ptr_b--;
                continue;
            }
            if (*ptr_a != *ptr_b) {
                return false;
            }
            else {
                ptr_a++;
                ptr_b--;
                continue;
            }
        }
        return true;
    }
};

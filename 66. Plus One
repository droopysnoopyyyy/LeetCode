class Solution {
public:
    vector<int> plusOne(vector<int>& digits) {
        int length = digits.size();
        for (int i = length-1; i >= 0; i--) {
            digits[i] += 1;
            if (digits[i] == 10) {
                digits[i] = 0;             
            }
            else {
                break;
            }
        }
        if (digits[0] == 0) {
            vector<int> newdigits (length+1); 
            newdigits[0] = 1;
            for (int i = 1; i < length+1; i++) {
                newdigits[i] = 0;
            }
            return newdigits;
        }
        return digits;
    }
};

class Solution {
public:
    bool containsDuplicate(vector<int>& nums) {
        unordered_map <int, int> freq;
        int length = nums.size();
        for (int i = 0; i < length; i++) {
            if (freq.count(nums[i]) == 0) {
                freq[nums[i]] += 1;
            }
            else return true;
        }
        return false;
    }
};

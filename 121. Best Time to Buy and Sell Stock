#include <bits/stdc++.h>
using namespace std;
class Solution {
public: 
    int maxProfit(vector<int>& prices) {
        int minimum = prices[0];
        int maximum_profit = 0;
        for (int i = 1; i < prices.size(); i++) {
            if (prices[i] < minimum) {
                minimum = prices[i];
            }
            if (prices[i] - minimum > maximum_profit) {
                maximum_profit = prices[i] - minimum;
            }
        }
        return maximum_profit;
    }
};
